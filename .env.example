# Database (Neon.tech pooled connection string)
DATABASE_URL="postgresql://username:password@host.neon.tech/jivnicare?sslmode=require"

# Auth — 32+ character random strings
JWT_SECRET="generate-using-openssl-rand-base64-32"
CRON_SECRET="generate-using-openssl-rand-base64-32"

# Cache / Rate limit — Upstash Redis
UPSTASH_REDIS_REST_URL="https://your-db-name.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-token"

# File uploads — Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="123456789012345"
CLOUDINARY_API_SECRET="your-api-secret"

# OTP SMS — 2Factor.in
TWOFACTOR_API_KEY="your-2factor-api-key"

# Email — Resend
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# Error tracking — Sentry
NEXT_PUBLIC_SENTRY_DSN="https://xxxxx@xxxxx.ingest.sentry.io/xxxxx"

# Admin 2FA — issuer name shown in TOTP apps (Google Authenticator etc.)
TOTP_ISSUER="JivniCare"

# App config
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"